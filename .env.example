# Flask Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# ENVIRONMENT SETTINGS
# ============================================================================

# Application environment: development, testing, production
FLASK_ENV=development

# Enable debug mode (development only, NEVER in production)
DEBUG=False

# Secret key for session encryption (generate a strong one for production!)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production

# JWT signing (defaults to SECRET_KEY if unset — set explicitly in production)
JWT_SECRET_KEY=

# Parallel workflows for POST /api/rounds/<id>/run (OpenAI Agents orchestrator)
ORCHESTRATION_PARALLEL_WORKFLOWS=2

# VirusTotal API Key for checking structural URLs via deterministic engine
# Get a free key at https://www.virustotal.com/gui/user/username/apikey
VT_API_KEY=


# ============================================================================
# DOCKER / POSTGRES CONFIGURATION
# ============================================================================

# PostgreSQL credentials for Docker Compose
# These are used by docker-compose.yml for the postgres service
POSTGRES_USER=phishing_user
POSTGRES_PASSWORD=phishing_password
POSTGRES_DB=phishing_db


# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Single URL used by some tools/tests (optional if DEV_/PROD_ are set)
# BaseConfig resolves: DATABASE_URL, then DEV_DATABASE_URL, then PROD_DATABASE_URL, then sqlite fallback
DATABASE_URL=

# Development database URL
# SQLite: sqlite:///app.db
# PostgreSQL: postgresql://username:password@localhost:5432/phishing_db
DEV_DATABASE_URL=sqlite:///app.db

# Production database URL (REQUIRED for production)
# PostgreSQL: postgresql://username:password@prod-host:5432/phishing_db
PROD_DATABASE_URL=postgresql://username:password@localhost:5432/phishing_db

# SQLAlchemy echo (log all SQL queries)
SQLALCHEMY_ECHO=False


# ============================================================================
# SESSION CONFIGURATION
# ============================================================================

# Session lifetime in days
SESSION_LIFETIME_DAYS=7

# Secure session cookie (HTTPS only) - set to False for dev (localhost)
SESSION_COOKIE_SECURE=False

# SameSite cookie policy: Strict, Lax, or None
SESSION_COOKIE_SAMESITE=Lax


# ============================================================================
# CORS CONFIGURATION
# ============================================================================

# Comma-separated list of allowed origins for cross-origin requests.
# Development: '*' allows all origins (acceptable for localhost only).
# Production:  Set to your exact frontend domain(s), e.g.:
#                CORS_ORIGINS=https://app.yourdomain.com
#              Multiple origins:
#                CORS_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com
# WARNING: Never use '*' in production — it allows any website to call your API.
CORS_ORIGINS=*


# ============================================================================
# API CONFIGURATION
# ============================================================================

# Maximum content length (in bytes) - default 16MB
MAX_CONTENT_LENGTH=16777216

# Server name for testing
TEST_SERVER_NAME=localhost:5000


# ============================================================================
# REDIS CONFIGURATION
# ============================================================================

# Redis URL for caching (optional - app degrades gracefully without it)
REDIS_URL=redis://localhost:6379/0


# ============================================================================
# LLM API CONFIGURATION (for agent services)
# ============================================================================

# OpenAI API key (required for Generator Agent + Orchestrator)
OPENAI_API_KEY=sk-...

# OpenAI Model
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude API Key (required for Detector Agent)
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini / Vertex (openai-agentic Generator uses GOOGLE_API_KEY; backend config also reads GEMINI_API_KEY)
GOOGLE_API_KEY=
GEMINI_API_KEY=

# VirusTotal API Key (optional, used for URL/file reputation checks in agents)
VT_API_KEY=
# Default timeout for LLM calls (seconds)
LLM_TIMEOUT=30

# Max tokens for each agent
GENERATOR_MAX_TOKENS=1000
DETECTOR_MAX_TOKENS=500


# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs/app.log

# Log max file size in MB
LOG_MAX_SIZE_MB=10

# Log backup count
LOG_BACKUP_COUNT=5


# ============================================================================
# EMAIL / SMTP CONFIGURATION (Flask-Mail — used for password reset emails)
# ============================================================================

# Frontend base URL used to build reset password links in emails
FRONTEND_URL=http://localhost:3000

# SMTP server settings
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False

# Your email account credentials
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Sender address shown in outgoing emails
MAIL_DEFAULT_SENDER=noreply@sentra.app

# Password reset token validity (in hours)
PASSWORD_RESET_EXPIRY_HOURS=1


# ============================================================================
# SEED COMMAND CONFIGURATION
# ============================================================================

# Admin account created by `flask seed` — REQUIRED (no default, seed skips admin if unset)
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=ChangeMe123

# Normal user seed account
SEED_USER_EMAIL=user@user.com
SEED_USER_USERNAME=testuser
SEED_USER_PASSWORD=ChangeMe123

# ============================================================================
# GGUF INFERENCE (Ollama)
# ============================================================================

# Ollama model to use for GGUF inference (auto-pulled on first scan if missing)
OLLAMA_MODEL=hf.co/duyle240820/sentra-utoledo-v2.0

# Ollama server URL — http://localhost:11434 when running via Docker Compose
# Change only if Ollama is hosted on a separate machine
OLLAMA_BASE_URL=http://localhost:11434


# ============================================================================
# PRODUCTION SETTINGS (DO NOT USE DEFAULTS!)
# ============================================================================

# For production, make sure to set:
# 1. FLASK_ENV=production
# 2. SECRET_KEY=<strong-random-key>
# 3. PROD_DATABASE_URL=<your-postgres-url>
# 4. OPENAI_API_KEY=<your-api-key>
# 5. ANTHROPIC_API_KEY=<your-anthropic-key>
# 6. SESSION_COOKIE_SECURE=True
# 7. DEBUG=False
# 8. CORS_ORIGINS=https://app.yourdomain.com  (never use '*' in production)
